// API Helpers Tests
import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';
import { buildApiUrl, apiCall, authenticatedApiCall, API_BASE_URL } from '../../config/api.js';

// Mock fetch globally
global.fetch = vi.fn();

describe('API Helpers', () => {
  beforeEach(() => {
    // Clear mocks before each test
    vi.clearAllMocks();
  });

  afterEach(() => {
    // Clean up after each test
    vi.restoreAllMocks();
  });

  describe('buildApiUrl', () => {
    it('should build correct URL for endpoint', () => {
      const url = buildApiUrl('/api/properties');

      expect(url).toBe('http://localhost:3456/api/properties');
    });

    it('should handle endpoint without leading slash', () => {
      const url = buildApiUrl('api/properties');

      expect(url).toBe('http://localhost:3456api/properties');
    });

    it('should handle endpoint with query parameters', () => {
      const url = buildApiUrl('/api/properties?city=Milano&type=Vendita');

      expect(url).toBe('http://localhost:3456/api/properties?city=Milano&type=Vendita');
    });

    it('should handle empty endpoint', () => {
      const url = buildApiUrl('');

      expect(url).toBe('http://localhost:3456');
    });
  });

  describe('apiCall', () => {
    it('should make API call with default headers', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({ success: true })
      });

      await apiCall('/api/test');

      expect(global.fetch).toHaveBeenCalledWith(
        'http://localhost:3456/api/test',
        {
          headers: {
            'Content-Type': 'application/json'
          }
        }
      );
    });

    it('should merge custom headers with defaults', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({ success: true })
      });

      await apiCall('/api/test', {
        headers: {
          'X-Custom-Header': 'custom-value'
        }
      });

      expect(global.fetch).toHaveBeenCalledWith(
        'http://localhost:3456/api/test',
        expect.objectContaining({
          headers: expect.any(Object)
        })
      );
    });

    it('should override default headers', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({ success: true })
      });

      await apiCall('/api/test', {
        headers: {
          'Content-Type': 'application/xml'
        }
      });

      expect(global.fetch).toHaveBeenCalledWith(
        'http://localhost:3456/api/test',
        expect.objectContaining({
          headers: expect.objectContaining({
            'Content-Type': 'application/xml'
          })
        })
      );
    });

    it('should pass through method and body', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({ success: true })
      });

      await apiCall('/api/test', {
        method: 'POST',
        body: JSON.stringify({ test: 'data' })
      });

      expect(global.fetch).toHaveBeenCalledWith(
        'http://localhost:3456/api/test',
        expect.objectContaining({
          method: 'POST',
          body: JSON.stringify({ test: 'data' })
        })
      );
    });

    it('should handle API errors gracefully', async () => {
      global.fetch.mockRejectedValueOnce(new Error('Network error'));

      await expect(apiCall('/api/test')).rejects.toThrow('Network error');
    });

    it('should return fetch response for success', async () => {
      const mockResponse = {
        ok: true,
        json: async () => ({ success: true, data: 'test' })
      };

      global.fetch.mockResolvedValueOnce(mockResponse);

      const response = await apiCall('/api/test');

      expect(response).toEqual(mockResponse);
      const data = await response.json();
      expect(data).toEqual({ success: true, data: 'test' });
    });
  });

  describe('authenticatedApiCall', () => {
    it('should add Authorization header with Bearer token', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({ success: true })
      });

      await authenticatedApiCall('/api/protected', 'test-token-123');

      expect(global.fetch).toHaveBeenCalledWith(
        'http://localhost:3456/api/protected',
        expect.objectContaining({
          headers: expect.objectContaining({
            'Authorization': 'Bearer test-token-123'
          })
        })
      );
    });

    it('should preserve default headers', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({ success: true })
      });

      await authenticatedApiCall('/api/protected', 'test-token');

      expect(global.fetch).toHaveBeenCalledWith(
        'http://localhost:3456/api/protected',
        expect.objectContaining({
          headers: expect.objectContaining({
            'Content-Type': 'application/json',
            'Authorization': 'Bearer test-token'
          })
        })
      );
    });

    it('should merge custom headers with auth headers', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({ success: true })
      });

      await authenticatedApiCall('/api/protected', 'test-token', {
        headers: {
          'X-Custom-Header': 'custom-value'
        }
      });

      expect(global.fetch).toHaveBeenCalledWith(
        'http://localhost:3456/api/protected',
        expect.objectContaining({
          headers: expect.objectContaining({
            'Content-Type': 'application/json',
            'Authorization': 'Bearer test-token',
            'X-Custom-Header': 'custom-value'
          })
        })
      );
    });

    it('should pass through custom options', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({ success: true })
      });

      await authenticatedApiCall('/api/protected', 'test-token', {
        method: 'POST',
        body: JSON.stringify({ action: 'test' })
      });

      expect(global.fetch).toHaveBeenCalledWith(
        'http://localhost:3456/api/protected',
        expect.objectContaining({
          method: 'POST',
          body: JSON.stringify({ action: 'test' }),
          headers: expect.objectContaining({
            'Authorization': 'Bearer test-token'
          })
        })
      );
    });

    it('should handle empty token', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({ success: true })
      });

      await authenticatedApiCall('/api/protected', '');

      expect(global.fetch).toHaveBeenCalledWith(
        'http://localhost:3456/api/protected',
        expect.objectContaining({
          headers: expect.objectContaining({
            'Authorization': 'Bearer '
          })
        })
      );
    });

    it('should handle API errors with auth', async () => {
      global.fetch.mockRejectedValueOnce(new Error('Network error'));

      await expect(
        authenticatedApiCall('/api/protected', 'token')
      ).rejects.toThrow('Network error');
    });
  });

  describe('API_BASE_URL constant', () => {
    it('should export correct base URL', () => {
      expect(API_BASE_URL).toBe('http://localhost:3456');
    });
  });

  describe('Integration scenarios', () => {
    it('should handle complete API call flow', async () => {
      const endpoint = '/api/properties';
      const fullUrl = buildApiUrl(endpoint);

      expect(fullUrl).toBe('http://localhost:3456/api/properties');

      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({
          success: true,
          properties: [
            { id: 1, title: 'Property 1' },
            { id: 2, title: 'Property 2' }
          ]
        })
      });

      const response = await apiCall(endpoint);
      const data = await response.json();

      expect(data.success).toBe(true);
      expect(data.properties).toHaveLength(2);
      expect(data.properties[0].title).toBe('Property 1');
    });

    it('should handle authenticated API call flow', async () => {
      const endpoint = '/api/users/profile';
      const token = 'jwt-token-123';
      const fullUrl = buildApiUrl(endpoint);

      expect(fullUrl).toBe('http://localhost:3456/api/users/profile');

      global.fetch.mockResolvedValueOnce({
        ok: true,
        json: async () => ({
          success: true,
          user: {
            id: 1,
            email: 'test@example.com',
            role: 'agent'
          }
        })
      });

      const response = await authenticatedApiCall(endpoint, token);
      const data = await response.json();

      expect(data.success).toBe(true);
      expect(data.user.email).toBe('test@example.com');
      expect(global.fetch).toHaveBeenCalledWith(
        fullUrl,
        expect.objectContaining({
          headers: expect.objectContaining({
            'Authorization': `Bearer ${token}`
          })
        })
      );
    });

    it('should handle error response correctly', async () => {
      global.fetch.mockResolvedValueOnce({
        ok: false,
        status: 404,
        json: async () => ({
          success: false,
          error: 'Resource not found'
        })
      });

      const response = await apiCall('/api/nonexistent');

      expect(response.ok).toBe(false);
      expect(response.status).toBe(404);

      const data = await response.json();
      expect(data.success).toBe(false);
      expect(data.error).toBe('Resource not found');
    });

    it('should handle timeout errors', async () => {
      global.fetch.mockRejectedValueOnce(
        new Error('Request timeout')
      );

      await expect(apiCall('/api/test')).rejects.toThrow('Request timeout');
    });
  });

  describe('Edge cases', () => {
    it('should handle special characters in endpoint', () => {
      const url = buildApiUrl('/api/search?q=Milano&types=appartment,villa');

      expect(url).toBe('http://localhost:3456/api/search?q=Milano&types=appartment,villa');
    });

    it('should handle unicode characters in endpoint', () => {
      const url = buildApiUrl('/api/search?city=Milano&zone=Roma+Città');

      expect(url).toBe('http://localhost:3456/api/search?city=Milano&zone=Roma+Città');
    });

    it('should handle very long endpoints', () => {
      const longQuery = '?'.padEnd(1000, 'a=b&');
      const url = buildApiUrl(`/api/search${longQuery}`);

      expect(url).toContain('http://localhost:3456/api/search');
      expect(url.length).toBeGreaterThan(1000);
    });

    it('should handle multiple concurrent API calls', async () => {
      global.fetch
        .mockResolvedValueOnce({
          ok: true,
          json: async () => ({ success: true, data: 'first' })
        })
        .mockResolvedValueOnce({
          ok: true,
          json: async () => ({ success: true, data: 'second' })
        })
        .mockResolvedValueOnce({
          ok: true,
          json: async () => ({ success: true, data: 'third' })
        });

      const [result1, result2, result3] = await Promise.all([
        apiCall('/api/first'),
        apiCall('/api/second'),
        apiCall('/api/third')
      ]);

      const data1 = await result1.json();
      const data2 = await result2.json();
      const data3 = await result3.json();

      expect(data1.data).toBe('first');
      expect(data2.data).toBe('second');
      expect(data3.data).toBe('third');
      expect(global.fetch).toHaveBeenCalledTimes(3);
    });
  });
});
