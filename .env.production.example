# AgenzieCase Production Environment Example
# Copy this to .env.production and fill in the actual values
# ⚠️ SECURITY: Never commit real credentials to git!

# Application
NODE_ENV=production
FRONTEND_PORT=80
BACKEND_PORT=3456

# Database Configuration
POSTGRES_USER=agenziecase_prod
POSTGRES_PASSWORD=your_secure_db_password_here_min_32_chars
POSTGRES_DB=agenziecase_prod
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here_min_32_chars

# Security
# ⚠️ Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_64_chars_hex_generated_above
JWT_EXPIRE=7d

# API Keys
# Get your keys from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Monitoring & Logging
# SENTRY_DSN=
# LOG_LEVEL=info

# Email Configuration (OVH SMTP)
# Configure your OVH email settings
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@agenziecase.com
SMTP_PASSWORD=your_ovh_email_password_here
EMAIL_FROM=info@agenziecase.com
EMAIL_FROM_NAME=AgenzieCase
EMAIL_REPLY_TO=info@agenziecase.com

# Frontend URL (for CORS)
FRONTEND_URL=https://agenziecase.com
